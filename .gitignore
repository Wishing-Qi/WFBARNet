# ========================================
# 视频文件（主要忽略项）
# ========================================
*.mp4
*.avi
*.mov
*.mkv
*.wmv
*.flv
*.webm
*.m4v
*.mpg
*.mpeg
*.3gp
*.ts
*.mts
*.m2ts
*.vob
*.ogv

# ========================================
# Python 缓存和编译文件
# ========================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg

# Virtual Environment
venv/
env/
ENV/
.venv

# Jupyter Notebook
.ipynb_checkpoints

# ========================================
