# ========================================
*.pth
*.pt

# ========================================
# 输出文件和日志
# ========================================
outputs/
logs/
.ultralytics/
*.log

# ========================================
# IDE 和编辑器配置
# ========================================
.vscode/
.idea/
*.swp
*.swo
*~

# OS 特定文件
.DS_Store
Thumbs.db

# ========================================
# 敏感文件
